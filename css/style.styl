// colors
:root
  --clr-bg #2D3035
  --clr-bg-light #393E46
  --clr-bg-lighter #505661
  --grad-aside-btn linear-gradient(0deg, #393e46 0, #505661 100%)
  --clr-accent-weak #d1c2ad
  --clr-accent #ffbe69
  --clr-accent-hover #ffa069
  --clr-txt #EEEEEE
  --clr-txt-darker #7E8998
  --clr-help-txt #ffffff

// font
:root
  --font-family 'Arial', 'Helvetica', 'sans-serif'
  --font-h1 600 52px/54px var(--font-family)
  --margin-h1 40px
  --font-h2 500 32px/36px var(--font-family)
  --margin-h2 28px
  --font-h3 500 24px/28px var(--font-family)
  --margin-h3 20px
  --font-base 400 18px/24px var(--font-family)
  --margin-base 20px
  --font-small 400 14px/18px var(--font-family)
  --margin-small 12px
  --font-tiny 300 12px/14px var(--font-family)
  --margin-tiny 8px
  @media (max-width: 1200px)
    --font-h1 600 44px/48px var(--font-family)
    --margin-h1 32px
    --font-h2 500 28px/32px var(--font-family)
    --margin-h2 24px
    --font-h3 500 22px/26px var(--font-family)
    --font-base 400 16px/20px var(--font-family)
  @media (max-width: 600px)
    --font-h1 600 28px/32px var(--font-family)
    --margin-h1 28px
    --font-h2 500 24px/28px var(--font-family)
    --margin-h2 20px
    --font-h3 500 20px/24px var(--font-family)
    --margin-h3 12px
    --font-base 400 14px/18px var(--font-family)
    --margin-base 12px
    --font-small 400 12px/16px var(--font-family)
    --margin-small 8px
    --font-tiny 300 10px/12px var(--font-family)
    --margin-tiny 6px

*, *::after, *::before
  box-sizing border-box

html
  scroll-behavior smooth
  scrollbar-width thin
  scrollbar-color var(--clr-txt-darker) var(--clr-bg)
  transition var(--trans-theme)

h1, h2, h3, h4, p
  margin 0

a
  color inherit

ul
  list-style-type none
  padding 0
  margin 0

.container
  margin 0 auto
  padding 0 56px 
  max-width 1680px
  @media (max-width: 1200px)
    padding 0 32px 
  @media (max-width: 900px)
    padding 0 24px 
  @media (max-width: 400px)
    padding 0 16px 

body
  margin 0
  font-family var(--font-family)
  background var(--clr-bg)
  color var(--clr-txt)

.content
  margin 20px 0
  padding 40px 32px
  background var(--clr-bg-lighter)
  border-radius 24px
  @media (max-width: 1200px)
    padding 32px 20px
  @media (max-width: 600px)
    padding 20px 12px
  &__title
    font var(--font-h1)
    text-align center
    margin-bottom var(--margin-base)
  &__desc
    font var(--font-base)
    text-align center
    margin-bottom var(--margin-h1)

.texts
  display grid
  grid-template-columns repeat(3, 1fr)
  gap 20px
  margin-bottom var(--margin-h1)
  @media (max-width: 1000px)
    grid-template-columns 1fr
  &-item
    padding 20px 16px 
    background var(--clr-bg-light)
    border-radius 12px
    &__name
      font var(--font-h3)
      margin-bottom var(--margin-base)
    &__desc
      font var(--font-base)
      margin-bottom var(--margin-base)
    &__input
      width 100%
      padding 12px 8px 
      background transparent
      resize vertical
      border 1px solid var(--clr-accent-weak)
      outline 0
      font inherit
      word-break break-word
      overflow auto
      scrollbar-width thin
      scrollbar-color var(--clr-accent) var(--clr-bg-light)
      color var(--clr-txt)
      border-radius 4px

#breakdown 
  & .texts-item__input
    & span.nbsp
      width 16px
      height 16px
      display inline-block
      background lime
      vertical-align middle

#breakdown 
  grid-column span 3
  @media (max-width: 1000px)
    grid-column span 1
  & .texts-item__input
    & span.nobr
      display inline-block
      background yellow
      padding 0 4px 
      color black
      vertical-align middle

.rules
  &__title
    font var(--font-h2)
    margin-bottom var(--margin-h3)
    text-align center 
  &-update
    display grid
    grid-template-columns repeat(2, 1fr)
    gap 20px
    @media (max-width: 1000px)
      grid-template-columns 1fr
    &-item
      &__name
        font var(--font-h3)
        margin-bottom var(--margin-base)
      &__row
        position relative
        width 100%
      &__input
        padding 12px 8px 
        padding-right 100px
        width 100%
        background transparent
        resize vertical
        border 1px solid var(--clr-accent)
        outline 0
        font inherit
        color var(--clr-txt)
        border-radius 4px
      &__submit
        position absolute
        top 0
        bottom 0
        right 0
        width 80px
        display flex
        justify-content center
        align-items center
        font var(--font-small)
        font-weight: 500
        color var(--clr-bg)
        background var(--clr-accent) 
        border 0
        border-radius 4px
        outline 0
        cursor pointer
        transition all .25s ease 
        &:hover
          background var(--clr-accent-hover) 
      &__list
        margin-top var(--margin-base) 
        display flex
        flex-wrap wrap
        gap 4px 8px
        &-item
          display inline-block
          font var(--font-base)
          color var(--clr-txt)
          padding 0
          background transparent
          border 0
          transition color .15s ease, text-shadow .15s ease
          cursor pointer
          &:not(:last-child)
            padding-right 6px
            border-right 1px solid  var(--clr-txt)
          &:hover
            color rgb(255, 80, 80)
            text-shadow 0 0 12px var(--clr-txt)
    &-reset
      grid-column span 2 
      padding-top 40px
      display flex
      justify-content center
      @media (max-width: 1000px)
        span 1
      &-btn
        padding 4px 12px
        display flex
        justify-content center
        align-items center
        font var(--font-small)
        font-weight: 500
        color var(--clr-txt-darker)
        background var(--clr-bg-light)
        border 0
        border-radius 4px
        outline 0
        cursor pointer
        transition all .25s ease 
        &:hover
          color var(--clr-txt)
          background rgb(255, 80, 80)
          text-decoration underline
      